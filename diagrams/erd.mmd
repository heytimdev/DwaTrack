erDiagram
    USERS {
        UUID    id PK
        VARCHAR first_name
        VARCHAR last_name
        VARCHAR email
        VARCHAR password_hash
        VARCHAR business_name
        VARCHAR business_email
        VARCHAR phone_number
        VARCHAR city
        TEXT    business_logo
        VARCHAR role
        VARCHAR country
        VARCHAR currency
        BOOLEAN tax_enabled
        VARCHAR tax_label
        NUMERIC tax_rate
        TIMESTAMPTZ created_at
    }

    TEAM_MEMBERS {
        UUID    id PK
        UUID    owner_id FK
        VARCHAR first_name
        VARCHAR last_name
        VARCHAR email
        VARCHAR password_hash
        VARCHAR role
        VARCHAR status
        TIMESTAMPTZ added_on
    }

    TRANSACTIONS {
        UUID    id PK
        UUID    owner_id FK
        VARCHAR receipt_number
        VARCHAR customer
        JSONB   items
        NUMERIC total
        NUMERIC tax_amount
        VARCHAR tax_label
        VARCHAR payment_method
        VARCHAR added_by
        VARCHAR status
        VARCHAR void_reason
        TIMESTAMPTZ voided_at
        TIMESTAMPTZ created_at
    }

    PRODUCTS {
        UUID    id PK
        UUID    owner_id FK
        VARCHAR name
        NUMERIC price
        NUMERIC cost_price
        VARCHAR category
        TIMESTAMPTZ created_at
    }

    EXPENSES {
        UUID    id PK
        UUID    owner_id FK
        VARCHAR description
        NUMERIC amount
        VARCHAR category
        VARCHAR added_by
        TIMESTAMPTZ created_at
    }

    STOCK {
        UUID    id PK
        UUID    owner_id FK
        VARCHAR name
        INTEGER quantity
        INTEGER low_stock_threshold
        TIMESTAMPTZ added_on
    }

    USERS ||--o{ TEAM_MEMBERS   : "has"
    USERS ||--o{ TRANSACTIONS   : "owns"
    USERS ||--o{ PRODUCTS       : "owns"
    USERS ||--o{ EXPENSES       : "owns"
    USERS ||--o{ STOCK          : "owns"
